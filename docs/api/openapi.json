{
  "openapi": "3.0.3",
  "info": {
    "title": "FastFeet API",
    "version": "1.0.0",
    "description": "Courier management API built with NestJS, Prisma, Clean Architecture and RBAC."
  },
  "servers": [
    {
      "url": "http://localhost:3333"
    }
  ],
  "tags": [
    { "name": "Auth" },
    { "name": "Deliverymen" },
    { "name": "Recipients" },
    { "name": "Orders" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "required": ["cpf", "password"],
        "properties": {
          "cpf": { "type": "string", "example": "11111111111" },
          "password": { "type": "string", "example": "123456" }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "accessToken": { "type": "string" },
          "userRole": { "type": "string", "enum": ["ADMIN", "DELIVERYMAN"] }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["waiting", "pickedUp", "delivered", "returned"]
          },
          "deliverymanId": { "type": "string", "nullable": true },
          "recipientId": { "type": "string" },
          "deliveryPhotoUrl": { "type": "string", "nullable": true }
        }
      },
      "CreateRecipientRequest": {
        "type": "object",
        "required": ["name", "address", "phone", "cpf", "latitude", "longitude"],
        "properties": {
          "name": { "type": "string" },
          "address": { "type": "string" },
          "phone": { "type": "string" },
          "cpf": { "type": "string" },
          "latitude": { "type": "number" },
          "longitude": { "type": "number" }
        }
      },
      "CreateDeliverymanRequest": {
        "type": "object",
        "required": ["name", "cpf", "password"],
        "properties": {
          "name": { "type": "string" },
          "cpf": { "type": "string" },
          "password": { "type": "string" }
        }
      },
      "CreateOrderRequest": {
        "type": "object",
        "required": ["name", "recipientId"],
        "properties": {
          "name": { "type": "string" },
          "recipientId": { "type": "string", "format": "uuid" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }] },
          "error": { "type": "string" },
          "statusCode": { "type": "integer" }
        }
      }
    }
  },
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Authenticate a user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Authenticated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponse" }
              }
            }
          },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/deliverymen": {
      "post": {
        "tags": ["Deliverymen"],
        "summary": "Create a deliveryman",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateDeliverymanRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" },
          "403": { "description": "Admin access required" },
          "409": { "description": "CPF already exists" }
        }
      }
    },
    "/recipients": {
      "post": {
        "tags": ["Recipients"],
        "summary": "Create a recipient",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateRecipientRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" },
          "403": { "description": "Admin access required" },
          "409": { "description": "CPF already exists" }
        }
      }
    },
    "/orders": {
      "post": {
        "tags": ["Orders"],
        "summary": "Create an order",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateOrderRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" },
          "403": { "description": "Admin access required" }
        }
      },
      "get": {
        "tags": ["Orders"],
        "summary": "List orders for admins",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "perPage", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": { "description": "Order list" },
          "403": { "description": "Admin access required" }
        }
      }
    },
    "/orders/{id}/waiting": {
      "patch": {
        "tags": ["Orders"],
        "summary": "Move an order back to waiting",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } } },
          "403": { "description": "Admin access required or invalid transition" },
          "404": { "description": "Order not found" }
        }
      }
    },
    "/orders/{id}/pick-up": {
      "patch": {
        "tags": ["Orders"],
        "summary": "Pick up an order",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } } },
          "403": { "description": "Only deliverymen can pick up waiting orders" },
          "404": { "description": "Order not found" }
        }
      }
    },
    "/orders/{id}/deliver": {
      "patch": {
        "tags": ["Orders"],
        "summary": "Deliver an order with multipart proof",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file"],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } } },
          "400": { "description": "Missing file or file too large" },
          "403": { "description": "Only the assigned deliveryman can deliver the order" },
          "404": { "description": "Order not found" },
          "415": { "description": "Unsupported proof file type" }
        }
      }
    },
    "/orders/{id}/return": {
      "patch": {
        "tags": ["Orders"],
        "summary": "Return an order",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } } },
          "403": { "description": "Only the assigned deliveryman can return the order" },
          "404": { "description": "Order not found" }
        }
      }
    },
    "/orders/nearby": {
      "get": {
        "tags": ["Orders"],
        "summary": "List nearby orders for the authenticated deliveryman",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "latitude", "in": "query", "required": true, "schema": { "type": "number" } },
          { "name": "longitude", "in": "query", "required": true, "schema": { "type": "number" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "perPage", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": { "description": "Order list" },
          "403": { "description": "Only deliverymen can list nearby orders" }
        }
      }
    },
    "/orders/my-deliveries": {
      "get": {
        "tags": ["Orders"],
        "summary": "List the authenticated deliveryman's deliveries",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "perPage", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": { "description": "Order list" },
          "403": { "description": "Only deliverymen can list their deliveries" }
        }
      }
    }
  }
}
