# Application
PORT=3333
APP_BASE_URL=http://localhost:3333
CORS_ORIGIN=http://localhost:3000

# Prisma
DATABASE_URL=postgresql://docker:docker@localhost:5432/fast-feet-api?schema=public

# Auth
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Storage
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=data/uploads
STORAGE_LOCAL_BASE_URL=http://localhost:3333/uploads

# R2 / S3 only
CLOUDFLARE_ACCOUNT_ID=
AWS_ENDPOINT_URL=
AWS_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
UPLOAD_PUBLIC_BASE_URL=
